# n8n Webhook URL
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/better-price-finder

# Google Sheets API
VITE_GOOGLE_SHEETS_API_KEY=your_google_api_key_here
VITE_GOOGLE_PRODUCTS_SHEET_ID=your_products_sheet_id_here
VITE_GOOGLE_PROCESS_HISTORY_SHEET_ID=your_process_history_sheet_id_here
VITE_GOOGLE_PRICES_HISTORY_SHEET_ID=your_prices_history_sheet_id_here

# Optional: default alert email
VITE_DEFAULT_ALERT_EMAIL=you@example.com

# Set to "true" to use mock data instead of real Google Sheets
VITE_USE_MOCK_DATA=true
