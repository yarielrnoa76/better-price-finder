# ── DEVELOPMENT ──────────────────────────────────────────────────────
# Copy to .env — never commit .env.

# true  → mock data, no Google credentials needed (local dev)
# false → live Google Sheets (production)
VITE_USE_MOCK_DATA=true

# ── n8n INTEGRATION ───────────────────────────────────────────────────
# n8n must have CORS enabled for your Cloudflare Pages domain:
#   Access-Control-Allow-Origin: https://<your-app>.pages.dev
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/better-price-finder

# ── GOOGLE SHEETS ─────────────────────────────────────────────────────
# Required when VITE_USE_MOCK_DATA=false.
# These are baked into the JS bundle at build time — use a read-only API key.
VITE_GOOGLE_SHEETS_API_KEY=your_google_api_key_here
VITE_GOOGLE_PRODUCTS_SHEET_ID=your_products_sheet_id_here
VITE_GOOGLE_PROCESS_HISTORY_SHEET_ID=your_process_history_sheet_id_here
VITE_GOOGLE_PRICES_HISTORY_SHEET_ID=your_prices_history_sheet_id_here

# ── MISC ──────────────────────────────────────────────────────────────
VITE_DEFAULT_ALERT_EMAIL=you@example.com

# ── SETTINGS PAGE ─────────────────────────────────────────────────────
# Password required to access the Settings page.
# If not set, the Settings page is accessible without a password (dev convenience).
VITE_MASTER_SETTINGS_PASSWORD=your_password_here
